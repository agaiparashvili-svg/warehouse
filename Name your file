name: Sync from pool-tracker

# ავტომატურად ეზიდება უახლეს ვერსიას pool-tracker/warehouse-იდან.
# მუშაობს ყოველ 10 წუთში, ან ხელით — Actions → "Sync from pool-tracker" → Run workflow.
on:
  schedule:
    - cron: '*/10 * * * *'
  workflow_dispatch: {}

permissions:
  contents: write

concurrency:
  group: sync
  cancel-in-progress: true

jobs:
  sync:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Fetch latest files from pool-tracker
        run: |
          base="https://raw.githubusercontent.com/agaiparashvili-svg/pool-tracker/main/warehouse"
          for f in index.html manifest.webmanifest sw.js; do
            curl -fsSL "$base/$f" -o "$f"
          done
          # flat layout: icons live at repo root here, not in an icons/ subfolder
          sed -i 's#icons/apple-touch-icon.png#apple-touch-icon.png#g' index.html
          sed -i 's#icons/##g' manifest.webmanifest
          sed -i 's#\./icons/#./#g' sw.js

      - name: Commit if changed
        run: |
          git config user.name "warehouse-sync"
          git config user.email "sync@users.noreply.github.com"
          git add index.html manifest.webmanifest sw.js
          if git diff --staged --quiet; then
            echo "Already up to date."
          else
            git commit -m "Auto-sync from pool-tracker"
            git push
          fi
YAML
